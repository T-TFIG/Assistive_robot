<?xml version="1.0"?>
<robot name="mobile_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- DUMMY ROOT -->
  <link name="base_link"/>

  <!-- ================= BASE ================= -->
  <link name="mobile_base">
        <inertial>
            <origin xyz="-8.800385241493517e-06 -5.080760325728716e-06 0.025" rpy="0.0 0.0 0.0" />
            <mass value="11.23397207252023" />
            <inertia ixx="0.03188466207652726" iyy="0.03188466206687757" izz="0.059431708806084234" ixy="-2.7855700399249703e-12" iyz="2.85555982343106e-18" ixz="2.8557715816678736e-18" />
        </inertial>

        <visual name="mobile_base_visual">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://mobile_robot/meshes/mobile_base.stl" 
                scale="0.001 0.001 0.001" />
            </geometry>
        </visual>

        <collision name="mobile_base_collision">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://mobile_robot/meshes/mobile_base.stl" 
                scale="0.001 0.001 0.001" />
            </geometry>
        </collision>

    </link>

    <!-- ================= WHEELS ================= -->
    <link name="Omni_wheel_single_part_1">
        <inertial>
            <origin xyz="2.667996426453101e-08 -2.100347451516882e-11 -0.011519236672568454" rpy="0.0 5.551115123125783e-17 0.0" />
            <mass value="1.9863292429901338" />
            <inertia ixx="0.0023009978909790713" iyy="0.0023010049853970926" izz="0.004188533048600424" ixy="-2.391454010736239e-17" iyz="1.949365611851438e-09" ixz="-1.1175897447063265e-12" />
        </inertial>

        <visual name="Omni_wheel_single_part_1_visual">
            <origin xyz="-2.5250001280952006e-08 0.01803143692017 -0.7384857201327312" rpy="1.5707963267948966 1.5707963267948966 0" />
            <geometry>
                <mesh filename="package://mobile_robot/meshes/Omni_wheel_single_part_1.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>

        <collision name="Omni_wheel_single_part_1_collision">
            <geometry>
                <cylinder radius="0.06" length="0.03"/>
            </geometry>
        </collision>

    </link>
    <link name="Omni_wheel_single_part_2">
        <inertial>
            <origin xyz="-2.965171094528908e-08 -2.0973471848151347e-11 -0.011480766058606663" rpy="0.0 -0.0 0.0" />
            <mass value="1.9863292429901338" />
            <inertia ixx="0.002300997890979005" iyy="0.002301004985396954" izz="0.004188533048600364" ixy="2.040714128172423e-17" iyz="-1.9493656151087224e-09" ixz="-1.1176083781606167e-12" />
        </inertial>

        <visual name="Omni_wheel_single_part_2_visual">
            <origin xyz="2.2278254551236784e-08 0.0180314369202 0.7154857174015561" rpy="1.5707963267948968 -1.5707963267948966 0" />
            <geometry>
                <mesh filename="package://mobile_robot/meshes/Omni_wheel_single_part_2.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>

        <collision name="Omni_wheel_single_part_2_collision">
            <geometry>
                <cylinder radius="0.06" length="0.03"/>
            </geometry>
        </collision>

    </link>
    <link name="Omni_wheel_single_part_3">
        <inertial>
            <origin xyz="-2.6421815952912874e-08 -2.0973471848151347e-11 -0.01148076871158981" rpy="0.0 -5.551115123125784e-17 0.0" />
            <mass value="1.9863292429901338" />
            <inertia ixx="0.002300997890978946" iyy="0.002301004985397072" izz="0.00418853304860031" ixy="2.2030600796904107e-17" iyz="-1.9493656133682033e-09" ixz="-1.1176717103905665e-12" />
        </inertial>

        <visual name="Omni_wheel_single_part_3_visual">
            <origin xyz="2.550814952151587e-08 0.0180314369202 0.7154857147485728" rpy="1.5707963267948968 -1.5707963267948966 0" />
            <geometry>
                <mesh filename="package://mobile_robot/meshes/Omni_wheel_single_part_3.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>

        <collision name="Omni_wheel_single_part_3_collision">

            <geometry>
                <cylinder radius="0.06" length="0.03"/>
            </geometry>
        </collision>    

    </link>

    <!-- ================= JOINTS ================= -->
    <joint name="base_link_to_mobile_base" type="fixed">
      <parent link="base_link"/>
      <child link="mobile_base"/>
    </joint>

    <joint name="mobile_base_Revolute-1" type="continuous">
        <origin xyz="-8.8e-06 0.17659745999999998 0.025" rpy="-1.5707963267948966 -0.0 0.0" />
        <parent link="mobile_base" />
        <child link="Omni_wheel_single_part_2" />
        <axis xyz="0.0 0.0 1.0" />
    </joint>

    <joint name="mobile_base_Revolute-2" type="continuous">
        <origin xyz="0.15293349 -0.08830634999999999 0.025" rpy="-1.5707963267948966 -0.0 -2.0943951023931953" />
        <parent link="mobile_base" />
        <child link="Omni_wheel_single_part_3" />
        <axis xyz="2.018922195534678e-07 0.0 0.9999996503124186" />
    </joint>

    <joint name="mobile_base_Revolute-3" type="continuous">
        <origin xyz="-0.15295109 -0.08830634999999999 0.025" rpy="-1.5707963267948966 -0.0 2.094395102393196" />
        <parent link="mobile_base" />
        <child link="Omni_wheel_single_part_1" />
        <axis xyz="-2.0189221860977824e-07 -0.0 0.9999996503124187" />
    </joint>

  <gazebo reference="Omni_wheel_single_part_1">
      <mu value="0.5"/>
      <mu2 value="0.01"/>
      <kp value="2000000.0" />
      <kd value="1000.0" />
      <minDepth value="0.0"/>
  </gazebo>

  <gazebo reference="Omni_wheel_single_part_2">
      <mu value="0.5"/>
      <mu2 value="0.01"/>
      <kp value="2000000.0" />
      <kd value="1000.0" />
      <minDepth value="0.0"/>
  </gazebo>

  <gazebo reference="Omni_wheel_single_part_3">
      <mu value="0.5"/>
      <mu2 value="0.01"/>
      <kp value="2000000.0" />
      <kd value="1000.0" />
      <minDepth value="0.0"/>
  </gazebo>
  
</robot>


<?xml version="1.0"?>
<robot name="mobile_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="base_link"/>

  <link name="mobile_base">
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <mass value="11.23"/>
      <inertia ixx="0.031" iyy="0.031" izz="0.059" ixy="0" iyz="0" ixz="0" />
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://mobile_robot/meshes/mobile_base.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.13" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_link_to_mobile_base" type="fixed">
    <parent link="base_link"/>
    <child link="mobile_base"/>
    <origin xyz="0 0 0.035" rpy="0 0 0"/> 
  </joint>

  <xacro:macro name="omni_wheel" params="prefix joint_name joint_xyz joint_rpy">
    <link name="Omni_wheel_single_part_${prefix}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1.98" />
        <inertia ixx="0.0023" iyy="0.0023" izz="0.0041" ixy="0" iyz="0" ixz="0" />
      </inertial>
      <visual>
        <geometry><cylinder radius="0.06" length="0.03"/></geometry>
      </visual>
      <collision>
        <geometry><cylinder radius="0.06" length="0.03"/></geometry>
      </collision>
    </link>

    <joint name="${joint_name}" type="continuous">
      <origin xyz="${joint_xyz}" rpy="${joint_rpy}"/>
      <parent link="mobile_base"/>
      <child link="Omni_wheel_single_part_${prefix}"/>
      <axis xyz="0 0 1"/>
    </joint>

    <gazebo reference="Omni_wheel_single_part_${prefix}">
      <mu1 value="0.5"/>
      <mu2 value="0.01"/> 
      <fdir1 value="1 0 0"/> 
      <kp value="2000000.0"/>
      <kd value="1000.0"/>
      <minDepth value="0.0"/>
    </gazebo>
  </xacro:macro>

  <xacro:omni_wheel prefix="2" joint_name="mobile_base_Revolute-1" joint_xyz="0.0 0.1766 0.025" joint_rpy="-1.5708 0 0"/>
  
  <xacro:omni_wheel prefix="3" joint_name="mobile_base_Revolute-2" joint_xyz="0.15294 -0.0883 0.025" joint_rpy="-1.5708 0 -2.0944"/>
  
  <xacro:omni_wheel prefix="1" joint_name="mobile_base_Revolute-3" joint_xyz="-0.15294 -0.0883 0.025" joint_rpy="-1.5708 0 2.0944"/>

</robot>
