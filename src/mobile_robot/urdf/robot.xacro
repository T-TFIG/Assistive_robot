<?xml version="1.0"?>
<robot name="mobile_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="red">
        <color rgba="1 0 0 1"/>
  </material>

  <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

  <link name="base_link"/>

  <link name="mobile_base">
    <inertial>
      <origin xyz="-8.80e-06 -5.08e-06 0.025" rpy="0 0 0" />
      <mass value="3"/>
      <inertia ixx="0.31" iyy="0.31" izz="0.59" ixy="0" iyz="0" ixz="0" />
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://mobile_robot/meshes/mobile_base.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.13" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_link_to_mobile_base" type="fixed">
    <parent link="base_link"/>
    <child link="mobile_base"/>
    <origin xyz="0 0 0.035" rpy="0 0 0"/> 
  </joint>

  <xacro:macro name="omni_wheel" params="prefix joint_name joint_xyz joint_rpy v_xyz v_rpy mesh_num">
    <link name="Omni_wheel_single_part_${prefix}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1" />
        <inertia ixx="0.023" iyy="0.023" izz="0.041" ixy="0" iyz="0" ixz="0" />
      </inertial>
      
      <visual>
        <origin xyz="${v_xyz}" rpy="${v_rpy}" />
        <geometry>
          <mesh filename="package://mobile_robot/meshes/Omni_wheel_single_part_${mesh_num}.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry><cylinder radius="0.06" length="0.03"/></geometry>
      </collision>
    </link>

    <joint name="${joint_name}" type="continuous">
      <origin xyz="${joint_xyz}" rpy="${joint_rpy}"/>
      <parent link="mobile_base"/>
      <child link="Omni_wheel_single_part_${prefix}"/>
      <axis xyz="0 0 1"/> 

      <dynamics damping="0.0" friction="0.0"/>
    </joint>

    <gazebo reference="Omni_wheel_single_part_${prefix}">
      <mu1 value="2.0"/> 
      <mu2 value="0.01"/>
      <fdir1 value="1 0 0"/>
      <kp value="10000000.0"/>
      <kd value="1.0"/>
      <minDepth value="0.001"/>
      <maxVel value="0.1"/>
    </gazebo>
  </xacro:macro>

  <xacro:omni_wheel 
    prefix="2" 
    mesh_num="2"
    joint_name="mobile_base_Revolute_3" 
    joint_xyz="0.0 0.1766 0.025" 
    joint_rpy="-1.5708 0 0"
    v_xyz="2.22e-08 0.018 0.715" 
    v_rpy="1.5708 -1.5708 0"/>
  
  <xacro:omni_wheel 
    prefix="3" 
    mesh_num="3"
    joint_name="mobile_base_Revolute_2" 
    joint_xyz="0.15294 -0.0883 0.025" 
    joint_rpy="-1.5708 0 -2.0944"
    v_xyz="2.55e-08 0.018 0.715" 
    v_rpy="1.5708 -1.5708 0"/>
  
  <xacro:omni_wheel 
    prefix="1" 
    mesh_num="1"
    joint_name="mobile_base_Revolute_1" 
    joint_xyz="-0.15294 -0.0883 0.025" 
    joint_rpy="-1.5708 0 2.0944"
    v_xyz="-2.52e-08 0.018 -0.738" 
    v_rpy="1.5708 1.5708 0"/>


  <physics type="ode">
    <real_time_update_rate>1000</real_time_update_rate>
    <max_step_size>0.001</max_step_size>
  </physics>

  <gazebo reference="ground_plane">
    <mu1>100.0</mu1>
    <mu2>100.0</mu2>
  </gazebo>

  <gazebo>
    <plugin name="gazebo_ros_p3d" filename="libgazebo_ros_p3d.so">
      <ros>
        <namespace>/ground_truth</namespace>
      </ros>
      <body_name>base_link</body_name>
      <frame_name>world</frame_name>
      <update_rate>50.0</update_rate>
      <xyz_offset>0 0 0</xyz_offset>
      <rpy_offset>0 0 0</rpy_offset>
      <gaussian_noise>0.0</gaussian_noise>
    </plugin>
  </gazebo>

</robot>